[user]
	name = redacted
	email = redacted@users.noreply.github.com
[init]
	defaultBranch = main
[pull]
	rebase = true
[core]
	editor = cursor --wait
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	light = false
[push]
	autoSetupRemote = true
[alias]
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit

