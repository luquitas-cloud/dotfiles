# === Font ===
font-family = "JetBrainsMono Nerd Font"
font-size = 14
font-thicken = true
font-feature = "calt"
font-feature = "liga"

# === Theme ===
theme = "Kanagawa Wave"

# === Window ===
background-opacity = 0.95
background-blur-radius = 30
window-padding-x = 18
window-padding-y = 14
window-padding-balance = true
window-theme = dark
macos-titlebar-style = transparent

# === Cursor ===
cursor-style = bar
cursor-style-blink = true
shell-integration-features = cursor,sudo,title

# === Behavior ===
mouse-hide-while-typing = true
copy-on-select = clipboard
confirm-close-surface = false
window-save-state = always

# === Quality of life ===
clipboard-read = allow
clipboard-write = allow

# === Hotkeys & Window Management ===
# Global dropdown (Quake-style) Quick Terminal from anywhere in macOS
keybind = global:cmd+shift+d=toggle_quick_terminal
quick-terminal-size = 50%


# Custom panel splitting controls (Vim-aligned splits)
keybind = cmd+d=new_split:right
keybind = cmd+shift+e=new_split:down




